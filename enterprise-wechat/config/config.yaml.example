wechat:
  corp_id: "YOUR_CORP_ID"
  corp_secret: "YOUR_CORP_SECRET"
  agent_id: "YOUR_AGENT_ID"
  callback_token: "YOUR_CALLBACK_TOKEN"
  callback_aes_key: "YOUR_CALLBACK_AES_KEY"

database:
  url: "sqlite:///./wechat.db"

# LLM 大模型配置
llm:
  provider: "sensenova"        # openai / claude / ollama / sensenova
  api_key: "YOUR_API_KEY"      # API Key (SenseNova / OpenAI / Claude)
  base_url: ""                 # API 地址，不填则使用默认地址
  model: "sensenova-6.7-flash-lite"  # 模型名称
  temperature: 0.7              # 生成温度 0-1
  max_tokens: 2000             # 最大 token 数

# RAG 知识库配置
rag:
  enabled: true
  embedding_provider: "openai"   # openai / ollama
  embedding_api_key: ""        # Embedding API Key（与 LLM API Key 相同）
  embedding_base_url: ""        # Embedding API 地址
  collection_name: "knowledge_base"
  persist_directory: "./data/chromadb"
  similarity_threshold: 0.5

# Agent 智能助手配置
agent:
  enabled: true
  use_rag: true
  system_prompt: ""

app:
  host: "0.0.0.0"
  port: 8000
  debug: false